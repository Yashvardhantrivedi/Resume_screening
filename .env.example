# ============================================================
# AI provider configuration
# Copy this file to .env.local and fill in ONE provider section.
# Without any key the app still works using rule-based parsing.
# ============================================================

# Which provider to use: groq | openai | anthropic | ollama | custom | none
# If left empty, the provider is inferred from whichever API key is set below.
LLM_PROVIDER=

# --- Option 1: Groq (free tier available — https://console.groq.com/keys) ---
GROQ_API_KEY=
# default model: llama-3.3-70b-versatile

# --- Option 2: OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=
# default model: gpt-5-mini

# --- Option 3: Anthropic Claude (https://console.anthropic.com/) ---
ANTHROPIC_API_KEY=
# default model: claude-opus-4-8 (for high volume, set LLM_MODEL=claude-haiku-4-5)

# --- Option 4: Ollama — local Llama models, no API key needed ---
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1   (from Docker: http://host.docker.internal:11434/v1)
# default model: llama3.2

# --- Option 5: Any other OpenAI-compatible API ---
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://your-provider.example.com/v1
# LLM_API_KEY=
# LLM_MODEL=

# Optional overrides (work with every provider):
# LLM_MODEL=    — override the default model
# LLM_API_KEY=  — generic key, used if the provider-specific var is empty
